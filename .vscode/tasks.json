{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Convert and Run Evaluator",
      "type": "shell",
      "command": "& 'C:\\Users\\zhiha\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe' txt_to_json.py '${input:transcriptTxtPath}' --batch-size '${input:evaluatorBatchSize}'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run Test Runner",
      "type": "shell",
      "command": "$py = 'C:\\Users\\zhiha\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe'; & $py 'tests\\response_test.py' --json | Out-File -FilePath 'tests\\test_cases.json' -Encoding utf8; powershell -NoProfile -ExecutionPolicy Bypass -File 'scripts\\start_pipeline_server.ps1' -OpenUrl 'http://localhost:3000/tests/test_runner.html?v=mistral-small-1'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Export Test Cases",
      "type": "shell",
      "command": "C:\\Users\\zhiha\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe tests\\response_test.py --json | Out-File -FilePath tests\\test_cases.json -Encoding utf8",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Open Evaluator",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File 'scripts\\start_pipeline_server.ps1' -OpenUrl 'http://localhost:3000/evaluator.html?v=mistral-small-1'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "transcriptTxtPath",
      "type": "promptString",
      "description": "TXT transcript path",
      "default": "input data/entire_interview_truncated.txt"
    },
    {
      "id": "evaluatorBatchSize",
      "type": "promptString",
      "description": "Evaluator batch size (1-7)",
      "default": "3"
    }
  ]
}
