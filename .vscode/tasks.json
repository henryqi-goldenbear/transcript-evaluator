{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "Convert and Run Evaluator",
      "type": "shell",
      "command": "& 'C:\\Users\\zhiha\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe' txt_to_json.py '${input:transcriptTxtPath}' --batch-size '${input:evaluatorBatchSize}'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    {
      "label": "Run Test Runner",
      "type": "shell",
      "command": "$py = 'C:\\Users\\zhiha\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe'; & $py response_test.py --json | Out-File -FilePath test_cases.json -Encoding utf8; Start-Process $py -ArgumentList '-m', 'http.server', '3000' -WorkingDirectory '${workspaceFolder}' -WindowStyle Hidden; Start-Sleep -Seconds 1; Start-Process 'http://localhost:3000/test_runner.html'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    {
      "label": "Export Test Cases",
      "type": "shell",
      "command": "C:\\Users\\zhiha\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe response_test.py --json | Out-File -FilePath test_cases.json -Encoding utf8",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    {
      "label": "Open Evaluator",
      "type": "shell",
      "command": "Start-Process 'C:\\Users\\zhiha\\AppData\\Local\\Python\\pythoncore-3.14-64\\python.exe' -ArgumentList '-m', 'http.server', '3000' -WorkingDirectory '${workspaceFolder}' -WindowStyle Hidden; Start-Sleep -Seconds 1; Start-Process 'http://localhost:3000/evaluator.html'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }

  ],
  "inputs": [
    {
      "id": "transcriptTxtPath",
      "type": "promptString",
      "description": "TXT transcript path",
      "default": "input data/entire_interview_truncated.txt"
    },
    {
      "id": "evaluatorBatchSize",
      "type": "promptString",
      "description": "Evaluator batch size (1-7)",
      "default": "3"
    }
  ]
}
